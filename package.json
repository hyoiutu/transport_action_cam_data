{
  "name": "transport-action-cam-data",
  "version": "1.0.0",
  "description": "Transport action camera data sorted by date YYYY-MM-DD",
  "type": "module",
  "main": "dist/main/main.js",
  "scripts": {
    "start": "npm run build && electron .",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "build": "npm run build:renderer && npm run build:main",
    "test:e2e": "npm run build && playwright test",
    "test:unit": "vitest run",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "exif-parser": "^0.1.12",
    "lucide-react": "^1.21.0",
    "music-metadata": "^7.14.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@playwright/test": "^1.61.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "^42.4.1",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "typescript": "^6.0.3",
    "vite": "^5.4.21",
    "vitest": "^4.1.9"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": "biome lint",
    "electron/**/*.ts": "biome lint",
    "style.css": "biome lint"
  }
}
